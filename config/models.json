{
  "default": "mobilenet",
  "models": [
    {
      "id": "mobilenet",
      "name": "MobileNetV2",
      "description": "Fast 2-class classifier · TFLite",
      "path": "../model/model.tflite",
      "backend": "tflite",
      "type": "classifier",
      "classes": ["With Mask", "Without Mask"],
      "input_size": [224, 224],
      "preprocessing": "mobilenet"
    },
    {
      "id": "vit",
      "name": "ViT Base",
      "description": "Vision Transformer · ONNX",
      "path": "../model/vit_model.onnx",
      "backend": "onnx",
      "type": "classifier",
      "classes": ["with_mask", "without_mask", "mask_weared_incorrectly"],
      "input_size": [224, 224],
      "preprocessing": "imagenet_nchw"
    },
    {
      "id": "faster_rcnn",
      "name": "Faster R-CNN",
      "description": "Detection + 3-class labels · ONNX",
      "path": "../model/faster_rcnn.onnx",
      "backend": "onnx",
      "type": "detector",
      "classes": ["__background__", "with_mask", "without_mask", "mask_weared_incorrect"],
      "input_size": [640, 640],
      "preprocessing": "rcnn_nchw",
      "conf_threshold": 0.5
    }
  ]
}
